{
  "info": {
    "name": "Nexus B2B Quote API",
    "description": "Complete collection of endpoints for the Nexus B2B Quote API. Note: Authentication uses http-only cookies, so login once and Postman will automatically send the cookie in subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Admin",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@nexusb2b.com\",\n    \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/login",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "login"]
            }
          }
        },
        {
          "name": "Get Current Admin",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/me",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "me"]
            }
          }
        },
        {
          "name": "Admin Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/admin/logout",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Customer Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"customer@example.com\",\n    \"password\": \"pass123\",\n    \"company_name\": \"Tech Innovators Inc.\",\n    \"company_title\": \"Tech Innovators Limited\",\n    \"tax_office\": \"Istanbul\",\n    \"tax_number\": \"1234567890\",\n    \"company_size\": \"10-50\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"customer@example.com\",\n    \"password\": \"pass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current Customer",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Logout Customer",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "3. User Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["user", "profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"company_name\": \"Tech Innovators Group\",\n    \"company_size\": \"50-200\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["user", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "laptop", "disabled": true },
                { "key": "category", "value": "Electronics", "disabled": true },
                { "key": "status", "value": "active", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Product Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/categories",
              "host": ["{{baseUrl}}"],
              "path": ["products", "categories"]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1"]
            }
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Industrial Server Rack\",\n    \"category\": \"IT Infrastructure\",\n    \"description\": \"42U Standard server rack for enterprise environments.\",\n    \"stock\": 50,\n    \"status\": \"active\",\n    \"images\": [\"https://example.com/rack.jpg\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"stock\": 45,\n    \"status\": \"out_of_stock\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1"]
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1"]
            }
          }
        },
        {
          "name": "Upload Product Image (Admin)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/products/1/images",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1", "images"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Quotes (Requests)",
      "item": [
        {
          "name": "Create Quote (Guest)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"guest_email\": \"guest@example.com\",\n    \"guest_company_name\": \"Guest Corp\",\n    \"note\": \"I need a bulk discount for these items.\",\n    \"items\": [\n        {\n            \"product_id\": 1,\n            \"quantity\": 10\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quotes",
              "host": ["{{baseUrl}}"],
              "path": ["quotes"]
            }
          }
        },
        {
          "name": "Create Quote (Logged In User)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"note\": \"Regular monthly supply request.\",\n    \"items\": [\n        {\n            \"product_id\": 1,\n            \"quantity\": 50\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quotes",
              "host": ["{{baseUrl}}"],
              "path": ["quotes"]
            }
          }
        },
        {
          "name": "Get All Quotes (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/quotes?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["quotes"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "pending", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get User's Quotes (Customer)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/quotes/user",
              "host": ["{{baseUrl}}"],
              "path": ["quotes", "user"]
            }
          }
        },
        {
          "name": "Get Quote Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/quotes/1",
              "host": ["{{baseUrl}}"],
              "path": ["quotes", "1"]
            }
          }
        },
        {
          "name": "Update Quote Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"responded\",\n    \"total_price\": 15000.00,\n    \"items\": [\n        {\n            \"id\": 1,\n            \"offered_price\": 1500.00\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quotes/1/status",
              "host": ["{{baseUrl}}"],
              "path": ["quotes", "1", "status"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    }
  ]
}
